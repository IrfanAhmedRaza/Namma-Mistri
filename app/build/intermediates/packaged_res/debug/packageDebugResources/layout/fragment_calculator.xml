<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:padding="16dp" android:background="#F5F5F5">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center_horizontal">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="📐 What to Calculate?" android:textSize="18sp" android:textStyle="bold" android:paddingBottom="8dp"/>
        <RadioGroup android:id="@+id/radioGroupCalcType" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="12dp">
            <RadioButton android:id="@+id/rbWall" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="🧱 Wall" android:textSize="16sp" android:checked="true"/>
            <RadioButton android:id="@+id/rbSlab" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="🏗️ Slab" android:textSize="16sp"/>
            <RadioButton android:id="@+id/rbPlaster" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="🎨 Plaster" android:textSize="16sp"/>
        </RadioGroup>
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Length (meters)" android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etLength"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:inputType="numberDecimal" android:textSize="18sp"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Height (meters)" android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etHeight"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:inputType="numberDecimal" android:textSize="18sp"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Width (meters) — for Slab only" android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etWidth"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:inputType="numberDecimal" android:textSize="18sp"/>
                </com.google.android.material.textfield.TextInputLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Wall Thickness:" android:textSize="16sp" android:paddingBottom="4dp"/>
                <Spinner android:id="@+id/spinnerThickness" android:layout_width="match_parent"
                    android:layout_height="56dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <Button android:id="@+id/btnCalculate" android:layout_width="0dp" android:layout_height="64dp"
                android:layout_weight="2" android:text="🧮 CALCULATE" android:textSize="18sp"
                android:textStyle="bold" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnClear" android:layout_width="0dp" android:layout_height="64dp"
                android:layout_weight="1" android:text="🗑️ Clear" android:textSize="16sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>
        <androidx.cardview.widget.CardView android:id="@+id/cardResult"
            android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone">
            <TextView android:id="@+id/tvResult" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:padding="16dp"
                android:textSize="16sp" android:fontFamily="monospace" android:background="#E8F5E9"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>