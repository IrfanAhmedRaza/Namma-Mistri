<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#F5F5F5">
    <Button android:id="@+id/btnAddWorker" android:layout_width="match_parent"
        android:layout_height="64dp" android:text="➕ ADD WORKER"
        android:textSize="18sp" android:textStyle="bold" android:layout_margin="12dp"/>
    <TextView android:id="@+id/tvNoWorkers" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="👷 No workers yet. Add your first worker!"
        android:textSize="16sp" android:textAlignment="center" android:padding="24dp" android:visibility="gone"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvWorkers"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="8dp" android:clipToPadding="false"/>
</LinearLayout>