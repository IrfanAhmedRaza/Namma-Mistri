<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <TextView android:id="@+id/tvWorkerTitle" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="22sp" android:textStyle="bold" android:paddingBottom="4dp"/>
        <TextView android:id="@+id/tvWageInfo" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="16sp" android:paddingBottom="12dp"/>
        <TextView android:id="@+id/tvSummary" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="15sp" android:fontFamily="monospace"
            android:background="#E8F5E9" android:padding="12dp" android:layout_marginBottom="16dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="📋 Log Today's Work" android:textSize="18sp" android:textStyle="bold" android:paddingBottom="8dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Days worked:" android:textSize="16sp" android:paddingBottom="4dp"/>
        <Spinner android:id="@+id/spinnerDays" android:layout_width="match_parent"
            android:layout_height="56dp" android:layout_marginBottom="12dp"/>
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Advance Paid Today (₹) — optional" android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etAdvance"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:textSize="18sp" android:inputType="numberDecimal"/>
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Note (optional)" android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etNote"
                android:layout_width="match_parent" android:layout_height="56dp" android:textSize="16sp"/>
        </com.google.android.material.textfield.TextInputLayout>
        <Button android:id="@+id/btnLogWork" android:layout_width="match_parent"
            android:layout_height="64dp" android:text="✅ LOG WORK"
            android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>
    </LinearLayout>
</ScrollView>